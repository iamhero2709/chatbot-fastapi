# Copy this file to .env and fill values before running the app

# Groq API key (REQUIRED)
GROQ_API_KEY=your_groq_api_key_here

# Optional: comma-separated origins allowed by CORS (used by FastAPI)
# For local Streamlit UI defaults to http://localhost:8501,http://127.0.0.1:8501
FRONTEND_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Which Groq model to use
GROQ_MODEL=llama3-8b-8192

# Optional: comma-separated fallback models to try if the primary model is decommissioned
# Example:
# GROQ_FALLBACK_MODELS=llama3-8b-4096,gpt-4o-mini
GROQ_FALLBACK_MODELS=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Safety knobs
TEMPERATURE=0.7
MAX_TOKENS=200
